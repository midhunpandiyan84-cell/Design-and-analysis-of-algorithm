def binary_search(arr, target):
    left = 0
    right = len(arr) - 1

    while left <= right:
        mid = (left + right) // 2

        if arr[mid] == target:
            return mid
        elif arr[mid] < target:
            left = mid + 1
        else:
            right = mid - 1

    return -1


numbers = [1, 2, 4, 7, 9, 12, 15]
result = binary_search(numbers, 9)

if result != -1:
    print("Found at index:", result)
else:
    print("Not found")
